# ─── Database ─────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/nielsens_logistics?schema=public"

# ─── NextAuth ─────────────────────────────────────────────
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ─── Google Cloud (OCR + Route Optimisation) ──────────────
GOOGLE_CLOUD_VISION_API_KEY=""
GOOGLE_MAPS_API_KEY=""

# ─── OpenAI (LLM fallback for OCR parsing) ───────────────
OPENAI_API_KEY=""

# ─── Postmark (Inbound Email) ────────────────────────────
POSTMARK_WEBHOOK_SECRET=""

# ─── App Config ───────────────────────────────────────────
NODE_ENV="development"
